  //     "bucket_name": "my-bucket"
  //   }
  // ],
  "d1_databases": [
    {
      "binding": "gold_vola_db",
      "database_name": "gold-vola-db",
      "database_id": "6e4ec3ab-640c-4f16-a2bd-fe549145b88c",
      "migrations_dir": "migrations"
    }
  ],
