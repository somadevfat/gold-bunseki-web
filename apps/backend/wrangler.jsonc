{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "gold-vola-backend",
  "vars": {
    "ANALYTICS_SERVICE_URL": "http://127.0.0.1:8000"
  },
  "main": "src/index.ts",
  "compatibility_date": "2026-03-27",
  "compatibility_flags": ["nodejs_compat"],
