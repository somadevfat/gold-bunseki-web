{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite dev --port 3001",
    "build": "vite build",
    "start": "wrangler dev",
    "lint": "eslint",
    "dev:mock": "bun run tests/mocks/http-server.ts",
    "deploy": "wrangler deploy",
    "test": "bun test src/",
    "test:coverage": "bun test src/ --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "hono": "^4.12.9",
    "lightweight-charts": "^5.1.0",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.30.3",
    "@cloudflare/workers-types": "^4.20260401.1",
    "@playwright/test": "^1.59.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "^1.3.11",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitejs/plugin-rsc": "^0.5.21",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "happy-dom": "^20.8.9",
    "msw": "^2.12.14",
    "react-server-dom-webpack": "^19.2.4",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vinext": "^0.0.38",
    "vite": "^8.0.3",
    "wrangler": "^4.79.0"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ],
  "type": "module",
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}