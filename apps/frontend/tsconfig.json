{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "types": [
      "@cloudflare/workers-types"
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "backend/*": [
        "../backend/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    "../backend/src/index.ts",
    "../backend/src/domain/**/*.ts",
    "../backend/src/application/port/**/*.ts",
    "../backend/src/interface/routes/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "../backend/src/**/*.test.ts"
  ]
}
