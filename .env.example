# GCP本番環境およびローカル用 .env テンプレート
# このファイルをコピーして .env を作成し、実運用に合わせて値を変更してください

# ================================
# バックエンド (Hono / db) の設定
# ================================
# --- Security ---
# API認証用のトークン。openssl rand -base64 32 などで生成した文字列を推奨。
API_TOKEN=your_super_secret_token_here

# 追加で許可するフロントエンドのドメイン（CORS/Better Auth trusted origins）。
# fanda-dev.com / www.fanda-dev.com / workers.dev / localhost:3001 はコード側で既定許可済み。
ALLOWED_ORIGINS=https://your-app.pages.dev

# --- Database ---
POSTGRES_USER=user
POSTGRES_PASSWORD=your_secure_db_password_here
POSTGRES_DB=gold_vola_db

# (Internal) Docker内部でのDB接続用URL
DATABASE_URL=postgres://user:your_secure_db_password_here@db:5432/gold_vola_db

# --- Authentication (better-auth / Google OAuth) ---
# 本番では https://api.fanda-dev.com を指定する
BETTER_AUTH_URL=https://api.fanda-dev.com
BETTER_AUTH_SECRET=replace_with_random_32_chars_or_longer
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret

# ================================
# 分析スクリプト (Python) の設定
# ================================
# 本番のバックエンドAPIのURL (VPSのIPなど) に向けます
# ex) HONO_SYNC_URL=http://35.x.x.x:3000/api/v1/sync/data
HONO_SYNC_URL=http://localhost:3000/api/v1/sync/data
