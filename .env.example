# GCP本番環境およびローカル用 .env テンプレート
# このファイルをコピーして .env を作成し、実運用に合わせて値を変更してください

# ================================
# バックエンド (Hono / db) の設定
# ================================
# --- Security ---
# API認証用のトークン。openssl rand -base64 32 などで生成した文字列を推奨。
API_TOKEN=your_super_secret_token_here

# フロントエンドのドメイン（CORS許可用）。コンマ区切りで複数指定可能。
ALLOWED_ORIGINS=http://localhost:5173,https://your-app.pages.dev

# --- Database ---
POSTGRES_USER=user
POSTGRES_PASSWORD=your_secure_db_password_here
POSTGRES_DB=gold_vola_db

# (Internal) Docker内部でのDB接続用URL
DATABASE_URL=postgres://user:your_secure_db_password_here@db:5432/gold_vola_db

# ================================
# 分析スクリプト (Python) の設定
# ================================
# 本番のバックエンドAPIのURL (VPSのIPなど) に向けます
# ex) HONO_SYNC_URL=http://35.x.x.x:3000/api/v1/sync/data
HONO_SYNC_URL=http://localhost:3000/api/v1/sync/data
