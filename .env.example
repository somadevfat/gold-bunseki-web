# GCP本番環境およびローカル用 .env テンプレート
# このファイルをコピーして .env を作成し、実運用に合わせて値を変更してください

# ================================
# バックエンド (Hono / db) の設定
# ================================
# 任意の複雑なパスワードに変更してください（Pythonスクリプトにも同じ値を設定します）
API_TOKEN=super_secret_token_12345

# フロントエンドのアクセス元を制限（複数の場合はカンマ区切り）
# CloudflareのURLやカスタムドメインを指定します
ALLOWED_ORIGINS=http://localhost:3001,https://gold-vola-frontend.somahiranodev.workers.dev

# ================================
# 分析スクリプト (Python) の設定
# ================================
# 本番のバックエンドAPIのURL (VPSのIPなど) に向けます
# ex) HONO_SYNC_URL=http://35.x.x.x:3000/api/v1/sync/data
HONO_SYNC_URL=http://localhost:3000/api/v1/sync/data
